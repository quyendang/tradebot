APP_NAME=tradebot
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CHECK_INTERVAL_SECONDS=600
REQUEST_TIMEOUT_SECONDS=20
EXCHANGE_BASE_URL=https://api.binance.com
EXCHANGE_PROVIDER=binance
DEFAULT_SYMBOLS=["BTCUSDT","ETHUSDT"]
DEFAULT_TIMEFRAMES=["1h","4h","1d"]
KLINE_LIMIT=300
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COOLDOWN_MINUTES=60
TELEGRAM_SCORE_DELTA=8
TELEGRAM_MIN_BUY_SCORE=72
TELEGRAM_MIN_SELL_SCORE=72
STATE_PATH=/app/data/state.json
